{
  "expo": {
    "name": "THF",
    "slug": "THF",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/THF/image.png",
    "splash": {
      "image": "./assets/THF/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "thf",
    "userInterfaceStyle": "automatic",
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/THF/image.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thfpartner.myapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow THF to access your camera to take photos for KYC and profile.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow THF to access your photos for uploading documents.",
          "cameraPermission": "Allow THF to access your camera to take photos for KYC and profile."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [],
          "color": "#E8304A"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a587d21-58fd-402f-9dcf-fc4018c345f2"
      }
    },
    "owner": "mohit551"
  }
}
