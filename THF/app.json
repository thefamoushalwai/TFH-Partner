{
  "expo": {
    "name": "THF",
    "slug": "THF",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/THF/image.png",
    "scheme": "thf",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/THF/image.png"

      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tfh.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
